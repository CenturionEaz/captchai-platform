# ─────────────────────────────────────────────────────────────────────────────
# CaptchaIQ Platform — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your values (see docs/SETUP.md for where to find each one)
# 3. NEVER commit .env.local to git
#
# Variables prefixed NEXT_PUBLIC_ are sent to the browser — keep them public-safe.
# All other variables are server-side only.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Dashboard → Project Settings → API → Service Role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Resend (Email) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=CaptchaIQ Research

# ── HuggingFace ──────────────────────────────────────────────────────────────
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_MODEL_CACHE=./model_cache

# ── Vercel (CI/CD only) ──────────────────────────────────────────────────────
# https://vercel.com/account/tokens
VERCEL_TOKEN=vcp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_ORG_ID=your-vercel-team-or-username

# ── Application URLs ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# ── Database (FastAPI backend only) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/captchaiq
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-generated-secret-key-minimum-32-characters

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_GENERATOR=true
NEXT_PUBLIC_FEATURE_LAB=true
NEXT_PUBLIC_FEATURE_REALTIME=true
