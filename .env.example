# ─── CaptchaIQ Platform — Environment Variables ──────────────────────────────
#
# Copy this file to .env (backend) or .env.local (frontend) and fill in values.
# NEVER commit actual secrets to version control.
#
# Required variables are marked [REQUIRED].
# Optional variables degrade gracefully if not set.
# ─────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# BACKEND — apps/api/.env
# ══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                          # development | production
SECRET_KEY=change-this-to-a-random-256-bit-key   # [REQUIRED in production]
DEBUG=false

# ── CORS — comma-separated list of allowed frontend origins ──────────────────
# In production: replace with your actual Vercel URL
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co   # [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here                # [REQUIRED]
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here            # [REQUIRED]

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Get from: https://huggingface.co/settings/tokens
# Free account works. Used for OCR, image classification, audio transcription.
HF_TOKEN=hf_your_token_here                      # [REQUIRED for AI features]

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── Email via Resend (optional) ───────────────────────────────────────────────
# Get from: https://resend.com — free tier: 3,000 emails/month
# If not set, emails are silently skipped — app still works fully.
RESEND_API_KEY=re_your_key_here
RESEND_FROM_NAME=CaptchaIQ Research
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=supabase     # supabase | local
LOCAL_STORAGE_PATH=./uploads

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND — apps/web/.env.local
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase (public — safe to expose to browser) ────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co   # [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here                # [REQUIRED]

# ── API URL — your deployed Render backend ────────────────────────────────────
NEXT_PUBLIC_API_URL=https://captchaiq-api.onrender.com          # [REQUIRED]
# For local dev:
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_APP_NAME=CaptchaIQ
